static uart: *mut u8 = 0x09000000u64 as *mut u8;

extern "C" {
    func putchar(c: i8) {
        *uart = c as u8;
    }

    func print(mut s: *const i8) {
        while *s != '\0' {
            putchar(*s);
            s = s + 1u64;
        }
    }

    func main() {
        print("Hello from Zircon!\n");
    }
}